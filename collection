{
	"info": {
		"name": "Library API Collection",
		"description": "Collection para testar a API de Livros com JWT, Filtros e JOINs",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"marquin\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "http://localhost:3000/register",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3000",
							"path": [
								"register"
							]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = JSON.parse(responseBody);",
									"postman.setEnvironmentVariable(\"token\", jsonData.token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"marquin\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "http://localhost:3000/login",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3000",
							"path": [
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "Books",
			"item": [
				{
					"name": "Get All Books (Filtros e Paginação)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:3000/books?page=1&limit=5&genre=Fantasia&sort=year&order=desc",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3000",
							"path": [
								"books"
							],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "5" },
								{ "key": "genre", "value": "Fantasia" },
								{ "key": "sort", "value": "year" },
								{ "key": "order", "value": "desc" }
							]
						}
					}
				},
				{
					"name": "Create Book",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"O Silmarillion\",\n    \"genre\": \"Fantasia\",\n    \"year\": 1977\n}"
						},
						"url": {
							"raw": "http://localhost:3000/books",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "3000",
							"path": [ "books" ]
						}
					}
				},
				{
					"name": "Update Book",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"O Hobbit (Edição Revisada)\",\n    \"genre\": \"Fantasia\",\n    \"year\": 1937\n}"
						},
						"url": {
							"raw": "http://localhost:3000/books/1",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "3000",
							"path": [ "books", "1" ]
						}
					}
				},
				{
					"name": "Delete Book",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "http://localhost:3000/books/1",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "3000",
							"path": [ "books", "1" ]
						}
					}
				},
				{
					"name": "Books Details (JOIN com User)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "http://localhost:3000/books-details",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "3000",
							"path": [ "books-details" ]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	]
}
